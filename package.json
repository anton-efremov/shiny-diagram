{
  "name": "shiny-poc",
  "displayName": "Shiny PoC",
  "description": "Proof of concept for source-backed visual editing of Mermaid diagrams.",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:shiny.openDiagram"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shiny.openDiagram",
        "title": "Shiny: Open Diagram",
        "icon": "$(preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "shiny.openDiagram",
          "when": "resourceExtname == .mmd",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run compile && npm run build:webview",
    "build:webview": "vite build",
    "compile": "tsc -p ./",
    "typecheck": "tsc -p ./ --noEmit && tsc -p ./tsconfig.webview.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.5.2",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
