classDiagram
direction TB
    class ConversationThread {
	    +UUID id
	    +List~TextMessage~ messages
	    +List~UserContact~ participants
	    +addMessage(TextMessage message) void
	    +addParticipant(UserContact participant) void
    }
    class ConversationThread_1 {
    	    +UUID id
    	    +List~TextMessage~ messages
    	    +List~UserContact~ participants
    	    +addMessage(TextMessage message) void
    	    +addParticipant(UserContact participant) void
    }

    class UserContact {
	    +UUID id
	    +String name
	    +String emailAddress
	    +List~CommunicationChannel~ preferredChannels
	    +addCommunicationChannel(CommunicationChannel channel) void
	    +removeCommunicationChannel(UUID channelId) void
    }

    ConversationThread --> UserContact : involves

    %% Native Style Applications
    class ConversationThread:::Rose
    class UserContact:::PineSelectedSelected
    class ConversationThread_1:::NewStyle

    %% Native Style Definitions
    classDef Rose stroke-width:1px,stroke-dasharray:none,stroke:#FF5978,fill:#ad3894,color:#050505
    classDef PineSelected stroke-width:1px,stroke-dasharray:none,stroke:#275340,fill:#3a8866,color:#FFFFFF
    classDef ShinyStyleSelected fill:#a76262,stroke:#37c368
    classDef BlueStyle fill:#626ea7,stroke:#37c368,fill:#a14f4a
    classDef NewStyle fill:#dd5555


    %% @spatial:ConversationThread x=-383 y=-44 w=228 h=210
    %% @spatial:ConversationThread_1 x=-119 y=146 w=228 h=210
    %% @spatial:UserContact x=-115 y=-49 w=200 h=150
    style UserContact fill:#932f2f
















